{
  "name": "nexus",
  "private": true,
  "description": "Workspace root — web app + gstack",
  "scripts": {
    "postinstall": "npm install --prefix .agents/skills/gstack && npm install --prefix web && npm install --prefix phantom/frontend",
    "dev": "npm run dev --prefix phantom/frontend",
    "dev:web": "npm run dev --prefix web",
    "build": "npm run build --prefix web",
    "preview": "npm run preview --prefix web",
    "dev:gstack": "npm run dev --prefix .agents/skills/gstack",
    "server": "npm run server --prefix .agents/skills/gstack",
    "start": "npm run start --prefix .agents/skills/gstack"
  }
}
